
#!/bin/sh
# configure script to build and install libffi to inst/libffi for Unix
set -e

> config.log
THISDir=`dirname $0`
THISDir=`realpath ${THISDir}`
MAKE=`"${R_HOME}/bin/R" CMD config MAKE`
CC=`"${R_HOME}/bin/R" CMD config CC`
CC=$(echo "${CC}" | awk '{print $1}')
AR=`"${R_HOME}/bin/R" CMD config AR`
RANLIB=`"${R_HOME}/bin/R" CMD config RANLIB`
LIBFFI_SRC="${THISDir}/src/libffi"
LIBFFI_DEST="${THISDir}/inst/libffi"
TINYCC_SRC="${THISDir}/src/tinycc"
TINYCC_DEST="${THISDir}/inst/tinycc"

# Unpack libffi tarball if needed
echo "Unpacking libffi tarball to ${LIBFFI_SRC} ..." >> config.log
"${R_HOME}/bin/Rscript" "${THISDir}/tools/vendorlibffi.R" unpack

if [ -d "$LIBFFI_SRC" ]; then
    cd "$LIBFFI_SRC"
    echo "$PWD"
    echo "Configuring and building libffi ..." >> config.log
    
    # On macOS, disable static library to avoid linking warnings
    # The R CMD check warns about symbols like _abort in static libraries
    CONFIGURE_FLAGS="--disable-docs --includedir=$LIBFFI_DEST/include --libdir=$LIBFFI_DEST/lib --prefix=$LIBFFI_DEST/build"
    if [ "$(uname)" = "Darwin" ]; then
        CONFIGURE_FLAGS="$CONFIGURE_FLAGS --disable-static --enable-shared"
        echo "macOS detected: building only shared library" >> config.log
    fi
    
    ./configure $CONFIGURE_FLAGS \
    CFLAGS="-fPIC -Wno-deprecated-declarations" \
        CC="$CC" AR="$AR" RANLIB="$RANLIB"
    mkdir -p "$LIBFFI_DEST/lib"
    mkdir -p "$LIBFFI_DEST/include"
    echo "Running make ..." >> config.log
    $MAKE >> config.log 2>&1
    echo "Running make install ..." >> config.log
    $MAKE install >> config.log 2>&1
    echo "libffi built and installed to $LIBFFI_DEST" >> config.log
    rm -rf "$LIBFFI_DEST/build"
    rm -rf "${LIBFFI_SRC}"

else
    echo "Error: libffi source directory $LIBFFI_SRC does not exist."
    exit 1
fi
cd "${THISDir}"
# Build TinyCC
echo "Unpacking tinycc tarball to ${TINYCC_SRC} ..." >> config.log
"${R_HOME}/bin/Rscript" "${THISDir}/tools/vendortinycc.R" unpack

if [ -d "$TINYCC_SRC" ]; then
    cd "$TINYCC_SRC"
    echo "$PWD"
    echo "Configuring and building tinycc ..." >> config.log
    
    # Configure TinyCC
    # Note: TinyCC's configure is simpler than autotools
    ./configure --prefix="$TINYCC_DEST" \
        --cc="$CC" \
        --ar="$AR" \
        --extra-cflags="-fPIC"
    
    mkdir -p "$TINYCC_DEST/lib"
    mkdir -p "$TINYCC_DEST/include"
    
    echo "Running make ..." >> config.log
    $MAKE >> config.log 2>&1
    
    echo "Running make install ..." >> config.log
    $MAKE install >> config.log 2>&1
    
    echo "tinycc built and installed to $TINYCC_DEST" >> config.log
    rm -rf "$TINYCC_SRC"
    
    # Test TinyCC preprocessing with difficult_structs.h
    cd "${THISDir}"
    echo "" >> config.log
    echo "=== Testing TinyCC preprocessing ===" >> config.log
    TCC_BIN="${TINYCC_DEST}/bin/tcc"
    TEST_HEADER="${THISDir}/inst/extdata/difficult_structs.h"
    
    if [ -f "$TCC_BIN" ] && [ -f "$TEST_HEADER" ]; then
        echo "TinyCC binary: $TCC_BIN" >> config.log
        echo "Test header: $TEST_HEADER" >> config.log
        
        # Get TinyCC version
        "$TCC_BIN" -v 2>&1 | head -1 >> config.log
        
        # Test preprocessing
        TMP_OUT=$(mktemp)
        echo "Running: $TCC_BIN -E $TEST_HEADER -o $TMP_OUT" >> config.log
        if "$TCC_BIN" -E -v "$TEST_HEADER" -o "$TMP_OUT" >> config.log 2>&1; then
            OUTPUT_SIZE=$(wc -c < "$TMP_OUT")
            OUTPUT_LINES=$(wc -l < "$TMP_OUT")
            echo "Preprocessing SUCCESS: $OUTPUT_SIZE bytes, $OUTPUT_LINES lines" >> config.log
            
            # Check if output is suspiciously small
            if [ "$OUTPUT_SIZE" -lt 5000 ]; then
                echo "WARNING: Preprocessed output is suspiciously small ($OUTPUT_SIZE bytes)" >> config.log
                echo "This may indicate TinyCC cannot process system headers properly" >> config.log
                echo "Last 20 lines of preprocessed output:" >> config.log
                tail -20 "$TMP_OUT" >> config.log
            else
                echo "Preprocessing appears successful (output size is reasonable)" >> config.log
            fi
        else
            echo "ERROR: TinyCC preprocessing failed" >> config.log
            echo "This may cause test failures related to header parsing" >> config.log
        fi
        rm -f "$TMP_OUT"
    else
        echo "Cannot test TinyCC: binary or test header not found" >> config.log
    fi
    echo "=== End TinyCC preprocessing test ===" >> config.log
    echo "" >> config.log
else
    echo "Error: tinycc source directory $TINYCC_SRC does not exist."
    exit 1
fi
